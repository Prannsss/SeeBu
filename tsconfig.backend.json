{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist-backend",
    "rootDir": "./backend/src"
  },
  "include": ["backend/src/**/*"],
  "exclude": ["node_modules", "**/*.test.ts"]
}